#!/usr/bin/env sh
# ==========================================
# Husky Pre-commit Hook for GhostFill
# ==========================================
#
# This hook runs before every commit to ensure:
# - Code is properly linted
# - Code is properly formatted
# - TypeScript types are correct
# - Tests pass for staged files
# - No secrets are committed
#
# SECURITY: Prevents committing sensitive data
# PERFORMANCE: Only runs on staged files
# ==========================================

# Exit on first error
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo "${BLUE}========================================${NC}"
echo "${BLUE}🔒 GhostFill Pre-commit Hook${NC}"
echo "${BLUE}========================================${NC}"
echo ""

# Get the directory of the current file
# This is needed to run commands from the project root
cd "$(dirname "$0")/.." || exit 1

# ==========================================
# Step 1: Run lint-staged
# ==========================================
echo "${YELLOW}Step 1/4: Running linter on staged files...${NC}"

if command -v npx &> /dev/null; then
    npx lint-staged
    echo "${GREEN}✓ Linting passed${NC}"
else
    echo "${RED}✗ npx not found. Please install Node.js${NC}"
    exit 1
fi

echo ""

# ==========================================
# Step 2: Run type check on staged files
# ==========================================
echo "${YELLOW}Step 2/4: Running TypeScript type check...${NC}"

# Get staged TypeScript files
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_TS_FILES" ]; then
    echo "Checking types for:"
    echo "$STAGED_TS_FILES" | sed 's/^/  - /'
    
    # Run type check (full project to catch cross-file issues)
    if npm run type-check; then
        echo "${GREEN}✓ Type check passed${NC}"
    else
        echo "${RED}✗ Type check failed${NC}"
        echo "${YELLOW}Hint: Run 'npm run type-check' to see all errors${NC}"
        exit 1
    fi
else
    echo "${GREEN}✓ No TypeScript files staged${NC}"
fi

echo ""

# ==========================================
# Step 3: Run tests on staged files
# ==========================================
echo "${YELLOW}Step 3/4: Running tests for changed files...${NC}"

# Get changed files (staged + unstaged for context)
CHANGED_FILES=$(git diff --name-only HEAD | grep -E '\.(ts|tsx)$' || true)

if [ -n "$CHANGED_FILES" ]; then
    echo "Running tests related to changed files..."
    
    # Extract test patterns from changed files
    TEST_PATTERNS=""
    for file in $CHANGED_FILES; do
        # Skip test files themselves
        if [[ "$file" == *".test."* ]] || [[ "$file" == *".spec."* ]]; then
            continue
        fi
        
        # Convert source file to test pattern
        dir=$(dirname "$file")
        base=$(basename "$file" .ts | sed 's/\.tsx$//')
        TEST_PATTERNS="$TEST_PATTERNS $dir/$base.test.ts $dir/$base.test.tsx"
    done
    
    if [ -n "$TEST_PATTERNS" ]; then
        echo "Test patterns: $TEST_PATTERNS"
        
        # Run matching tests
        if npx vitest run $TEST_PATTERNS --passWithNoTests; then
            echo "${GREEN}✓ Tests passed${NC}"
        else
            echo "${RED}✗ Tests failed${NC}"
            echo "${YELLOW}Hint: Run 'npm run test' to see all test results${NC}"
            exit 1
        fi
    else
        echo "${GREEN}✓ No tests to run${NC}"
    fi
else
    echo "${GREEN}✓ No changed files${NC}"
fi

echo ""

# ==========================================
# Step 4: Check for secrets
# ==========================================
echo "${YELLOW}Step 4/4: Checking for secrets in staged files...${NC}"

# Check for common secret patterns in staged files
SECRETS_FOUND=false

# Patterns to check (simplified for shell)
SECRET_PATTERNS=(
    "password\s*[=:]\s*['\"][^'\"]+['\"]"
    "api_key\s*[=:]\s*['\"][^'\"]+['\"]"
    "apikey\s*[=:]\s*['\"][^'\"]+['\"]"
    "secret\s*[=:]\s*['\"][^'\"]+['\"]"
    "token\s*[=:]\s*['\"][A-Za-z0-9-_]+\.[A-Za-z0-9-_]+"
    "AWS[A-Z0-9]{10,}"
    "ghp_[A-Za-z0-9]{36}"
    "sk-[A-Za-z0-9]{32,}"
)

STAGED_CONTENT=$(git diff --cached)

for pattern in "${SECRET_PATTERNS[@]}"; do
    if echo "$STAGED_CONTENT" | grep -iE "$pattern" > /dev/null 2>&1; then
        echo "${RED}⚠ Potential secret detected matching pattern: $pattern${NC}"
        SECRETS_FOUND=true
    fi
done

if [ "$SECRETS_FOUND" = true ]; then
    echo ""
    echo "${RED}========================================${NC}"
    echo "${RED}⚠️  POTENTIAL SECRETS DETECTED!${NC}"
    echo "${RED}========================================${NC}"
    echo ""
    echo "Please review the staged changes for sensitive data."
    echo "Consider using environment variables or a secrets manager."
    echo ""
    echo "To bypass this check (NOT RECOMMENDED), use:"
    echo "  git commit --no-verify"
    echo ""
    exit 1
else
    echo "${GREEN}✓ No secrets detected${NC}"
fi

echo ""
echo "${BLUE}========================================${NC}"
echo "${GREEN}✅ All pre-commit checks passed!${NC}"
echo "${BLUE}========================================${NC}"
echo ""

# Success
exit 0
