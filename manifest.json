{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.1.0",
  "description": "__MSG_extensionDescription__",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.gstatic.com/ https://*.googleusercontent.com/; worker-src 'none'; child-src 'none'; frame-src 'none'; connect-src 'self' https://api.1secmail.com https://api.1secmail.net https://api.1secmail.org https://www.1secmail.com https://api.mail.tm https://api.mail.gw https://api.tmailor.com https://api.maildrop.cc https://api.dropmail.me https://api.guerrillamail.com https://api.tempmail.lol https://mercure.mail.tm https://www.googleapis.com/ https://oauth2.googleapis.com/ https://mail.google.com/ https://accounts.google.com/;"
  },
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "contextMenus",
    "alarms",
    "notifications",
    "offscreen",
    "identity",
    "scripting",
    "tabs",
    "downloads"
  ],
  "oauth2": {
    "client_id": "459266010400-dolmu9evfqce3ijg3gggpp7r39ohc4kn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": [
    "https://api.1secmail.com/*",
    "https://api.1secmail.net/*",
    "https://api.1secmail.org/*",
    "https://www.1secmail.com/*",
    "https://api.mail.tm/*",
    "https://api.mail.gw/*",
    "https://api.tmailor.com/*",
    "https://api.maildrop.cc/*",
    "https://api.dropmail.me/*",
    "https://api.guerrillamail.com/*",
    "https://api.tempmail.lol/*",
    "https://mercure.mail.tm/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "exclude_matches": [
        "*://*.chase.com/*",
        "*://*.bankofamerica.com/*",
        "*://*.wellsfargo.com/*",
        "*://*.citibank.com/*",
        "*://*.capitalone.com/*",
        "*://*.usbank.com/*",
        "*://*.pnc.com/*",
        "*://*.td.com/*",
        "*://*.bbt.com/*",
        "*://*.suntrust.com/*",
        "*://*.regions.com/*",
        "*://*.key.com/*",
        "*://*.fifththird.com/*",
        "*://*.ally.com/*",
        "*://*.schwab.com/*",
        "*://*.fidelity.com/*",
        "*://*.vanguard.com/*",
        "*://*.etrade.com/*",
        "*://*.tdameritrade.com/*",
        "*://*.interactivebrokers.com/*",
        "*://*.barclays.co.uk/*",
        "*://*.hsbc.co.uk/*",
        "*://*.santander.co.uk/*",
        "*://*.rbcroyalbank.com/*",
        "*://*.scotiabank.com/*",
        "*://*.bmo.com/*",
        "*://*.cibc.com/*",
        "*://*.commbank.com.au/*",
        "*://*.westpac.com.au/*",
        "*://*.nab.com.au/*",
        "*://*.anz.com.au/*",
        "*://*.1password.com/*",
        "*://*.lastpass.com/*",
        "*://*.dashlane.com/*",
        "*://*.bitwarden.com/*",
        "*://*.keeper-security.com/*",
        "*://*.roboform.com/*",
        "*://*.norton.com/password-manager/*",
        "*://*.mcafee.com/identity-protection/*",
        "*://chrome.google.com/*",
        "*://chromewebstore.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false,
      "match_about_blank": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "GhostFill"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/icon128.png"],
      "matches": ["https://*/*"],
      "use_dynamic_url": true
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open GhostFill"
    },
    "generate-email": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Generate new temp email"
    },
    "generate-password": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Generate new password"
    },
    "auto-fill": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Auto-fill current form"
    }
  },
  "default_locale": "en",
  "minimum_chrome_version": "109"
}
