#!/usr/bin/env sh
# ==========================================
# Husky Pre-push Hook for GhostFill
# ==========================================
#
# This hook runs before pushing to remote:
# - Runs full test suite
# - Ensures build succeeds
# - Checks for large files
#
# SECURITY: Prevents pushing broken code
# PERFORMANCE: Runs critical checks only
# ==========================================

# Exit on first error
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo "${BLUE}========================================${NC}"
echo "${BLUE}🚀 GhostFill Pre-push Hook${NC}"
echo "${BLUE}========================================${NC}"
echo ""

# Get the directory of the current file
cd "$(dirname "$0")/.." || exit 1

# ==========================================
# Step 1: Run full test suite
# ==========================================
echo "${YELLOW}Step 1/3: Running full test suite...${NC}"

if npm run test:unit -- --passWithNoTests; then
    echo "${GREEN}✓ Unit tests passed${NC}"
else
    echo "${RED}✗ Unit tests failed${NC}"
    echo "${YELLOW}Please fix failing tests before pushing${NC}"
    exit 1
fi

echo ""

# ==========================================
# Step 2: Verify build succeeds
# ==========================================
echo "${YELLOW}Step 2/3: Verifying build...${NC}"

if npm run build; then
    echo "${GREEN}✓ Build succeeded${NC}"
else
    echo "${RED}✗ Build failed${NC}"
    echo "${YELLOW}Please fix build errors before pushing${NC}"
    exit 1
fi

echo ""

# ==========================================
# Step 3: Check for large files
# ==========================================
echo "${YELLOW}Step 3/3: Checking for large files...${NC}"

# Maximum file size (in bytes) - 5MB
MAX_FILE_SIZE=5242880

LARGE_FILES=$(git diff --name-only "$2" "$1" | while read file; do
    if [ -f "$file" ]; then
        size=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
        if [ "$size" -gt "$MAX_FILE_SIZE" ]; then
            echo "$file ($(numfmt --to=iec-i --suffix=B "$size" 2>/dev/null || echo "${size}B"))"
        fi
    fi
done || true)

if [ -n "$LARGE_FILES" ]; then
    echo "${RED}⚠ Large files detected:${NC}"
    echo "$LARGE_FILES" | sed 's/^/  - /'
    echo ""
    echo "Files larger than 5MB should not be committed to Git."
    echo "Consider using Git LFS or storing large files externally."
    echo ""
    echo "To bypass this check, use:"
    echo "  git push --no-verify"
    echo ""
    exit 1
else
    echo "${GREEN}✓ No large files detected${NC}"
fi

echo ""
echo "${BLUE}========================================${NC}"
echo "${GREEN}✅ All pre-push checks passed!${NC}"
echo "${BLUE}========================================${NC}"
echo ""

# Success
exit 0
