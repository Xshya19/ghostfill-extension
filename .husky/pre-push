#!/usr/bin/env sh
# ==========================================
# Husky Pre-push Hook for GhostFill
# ==========================================
# Runs tests and build before pushing.
# Compatible with both Unix and Git Bash on Windows.
# ==========================================

set -e

echo "[pre-push] Running test suite..."
npm run test || { echo "[pre-push] Tests failed"; exit 1; }

echo "[pre-push] Verifying build..."
npm run build || { echo "[pre-push] Build failed"; exit 1; }

echo "[pre-push] All checks passed!"
exit 0
