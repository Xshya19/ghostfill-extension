{
  "name": "ghostfill-extension",
  "version": "1.1.0",
  "description": "Disposable emails, secure passwords, and automatic OTP detection & fill. Local AI engine — no API key required. 100% Free & Open Source.",
  "private": true,
  "scripts": {
    "dev": "webpack --watch --mode=development",
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "zip": "node scripts/build-zip.js",
    "build:zip": "npm run zip"
  },
  "keywords": [
    "chrome-extension",
    "disposable-email",
    "temp-email",
    "password-generator",
    "otp",
    "autofill",
    "privacy",
    "manifest-v3"
  ],
  "author": "GhostFill",
  "license": "MIT",
  "dependencies": {
    "framer-motion": "^12.23.26",
    "isomorphic-dompurify": "^3.1.0",
    "lucide-react": "^0.562.0",
    "onnxruntime-web": "^1.24.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/ui": "^4.1.0",
    "archiver": "^7.0.1",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^4.0.0",
    "html-webpack-plugin": "^5.6.0",
    "jsdom": "^29.0.0",
    "mini-css-extract-plugin": "^2.7.6",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
